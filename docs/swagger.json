{
    "swagger": "2.0",
    "info": {
        "description": "This is a sample swagger for Fiber",
        "title": "TB App API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "email": "fiber@swagger.io"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:3000",
    "basePath": "/api/v1",
    "paths": {
        "/users": {
            "get": {
                "description": "Menampilkan semua system admin yang terdaftar di sistem.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Mengambil daftar semua system admin",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal.ListSystemAdminsRow"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Membuat user dan menetapkannya sebagai system admin. Jika password diisi, akan di-hash.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Mendaftarkan system admin baru",
                "parameters": [
                    {
                        "description": "Data Admin",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/modules_users.CreateSystemAdminRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal.GetSystemAdminByIDRow"
                        }
                    }
                }
            }
        },
        "/users/{id}": {
            "get": {
                "description": "Menampilkan informasi lengkap admin tertentu.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Mengambil detail admin berdasarkan ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal.GetSystemAdminByIDRow"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "put": {
                "description": "Mengubah informasi profil, foto, atau level admin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Memperbarui data system admin",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Data Update",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/modules_users.UpdateSystemAdminRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal.GetSystemAdminByIDRow"
                        }
                    }
                }
            },
            "delete": {
                "description": "Menghapus user dari sistem berdasarkan ID. Menghapus otomatis akses admin karena Cascade.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Menghapus user dan admin",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal.AdminLevel": {
            "type": "string",
            "enum": [
                "SUPERADMIN",
                "ADMIN"
            ],
            "x-enum-varnames": [
                "AdminLevelSUPERADMIN",
                "AdminLevelADMIN"
            ]
        },
        "internal.GetSystemAdminByIDRow": {
            "type": "object",
            "properties": {
                "admin_level": {
                    "$ref": "#/definitions/internal.AdminLevel"
                },
                "created_at": {
                    "$ref": "#/definitions/pgtype.Timestamptz"
                },
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "image": {
                    "$ref": "#/definitions/pgtype.Text"
                },
                "is_active": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "internal.ListSystemAdminsRow": {
            "type": "object",
            "properties": {
                "admin_level": {
                    "$ref": "#/definitions/internal.AdminLevel"
                },
                "created_at": {
                    "$ref": "#/definitions/pgtype.Timestamptz"
                },
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "is_active": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "modules_users.CreateSystemAdminRequest": {
            "type": "object",
            "required": [
                "level"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "abu@example.com"
                },
                "level": {
                    "type": "string",
                    "enum": [
                        "SUPERADMIN",
                        "ADMIN"
                    ],
                    "example": "SUPERADMIN"
                },
                "name": {
                    "type": "string",
                    "example": "Abunawas"
                },
                "password": {
                    "type": "string",
                    "example": "rahasia123"
                }
            }
        },
        "modules_users.UpdateSystemAdminRequest": {
            "type": "object",
            "required": [
                "level"
            ],
            "properties": {
                "is_active": {
                    "type": "boolean",
                    "example": true
                },
                "level": {
                    "type": "string",
                    "enum": [
                        "SUPERADMIN",
                        "ADMIN"
                    ],
                    "example": "ADMIN"
                },
                "name": {
                    "type": "string",
                    "example": "Abunawas Updated"
                }
            }
        },
        "pgtype.InfinityModifier": {
            "type": "integer",
            "format": "int32",
            "enum": [
                1,
                0,
                -1
            ],
            "x-enum-varnames": [
                "Infinity",
                "Finite",
                "NegativeInfinity"
            ]
        },
        "pgtype.Text": {
            "type": "object",
            "properties": {
                "string": {
                    "type": "string"
                },
                "valid": {
                    "type": "boolean"
                }
            }
        },
        "pgtype.Timestamptz": {
            "type": "object",
            "properties": {
                "infinityModifier": {
                    "$ref": "#/definitions/pgtype.InfinityModifier"
                },
                "time": {
                    "type": "string"
                },
                "valid": {
                    "type": "boolean"
                }
            }
        }
    }
}